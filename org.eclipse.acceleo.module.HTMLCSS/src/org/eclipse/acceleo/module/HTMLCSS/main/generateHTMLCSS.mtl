[template public generateCuestionario(q : Cuestionario)]
[file (q.Nombre.toLowerCase().concat('.html'), false, 'UTF-8')]
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Cuestionario: [q.Nombre/]</title>
  <link rel="stylesheet" href="styles.css">
</head>
<body>
  <div class="header">
    <h1>Cuestionario: [q.Nombre/]</h1>
    [if (q.Evaluado)]
      <p><strong>Este cuestionario es evaluado</strong></p>
    [/if]
  </div>

  <div class="social">
    <h3>Redes sociales:</h3>
    [for (rs : RedSocial | q.redsocial)]
      <p>- <a href="https://www.[rs.Nombre.toLowerCase()/].com">[rs.Nombre/]</a></p>
    [/for]
  </div>

  <form>
    [for (p : PreguntaCuestionario | q.preguntascuestionario)]
      <div class="question">
        <p><strong>[p.Texto/]</strong></p>
         
        [if (p.Tipo = TipoPregunta::OpcionMultiple)]
          [for (r : RespuestaCuestionario | p.respuestas_cuestionario)]
            <input type="radio" name="pregunta_[p.Texto/]" value="[r.Texto/]" required> [r.Texto/]<br/>
          [/for]
        [/if]

        [if (p.Tipo = TipoPregunta::V_F)]
          <input type="radio" name="pregunta_[p.Texto/]" value="true" required> Verdadero<br/>
          <input type="radio" name="pregunta_[p.Texto/]" value="false" required> Falso<br/>
        [/if]

        [if (p.Tipo = TipoPregunta::Corta)]
          <input type="text" name="pregunta_[p.Texto/]" placeholder="Tu respuesta..." required><br/>
        [/if]

        [if (q.Evaluado)]
          <div class="correct-answer">
            <strong>Respuesta correcta:</strong> 
            [for (r : RespuestaCuestionario | p.respuestas_cuestionario)]
              [  r.correcta.Texto / ]
            [/for]
          </div>
        [/if]
      </div>
    [/for]

    <div class="actions">
      <button type="submit">Enviar Cuestionario</button>
      <button type="button" onclick="window.location.href='[q.usuario.Nombre.toLowerCase()/]/index.html'">Cancelar</button>
    </div>
  </form>
</body>
</html>
[/file]
[/template]

[template public generateEncuesta(e : Encuesta)]
[file (e.Nombre.toLowerCase().concat('.html'), false, 'UTF-8')]
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Encuesta: [e.Nombre/]</title>
  <link rel="stylesheet" href="styles.css">
</head>
<body>
  <div class="header">
    <h1>Encuesta: [e.Nombre/]</h1>
    <p>[e.Descripcion/]</p>
  </div>

  <div class="social">
    <h3>Redes sociales:</h3>
    [for (rs : RedSocial | e.redsocial)]
      <p>- <a href="https://www.[rs.Nombre.toLowerCase()/].com">[rs.Nombre/]</a></p>
    [/for]
  </div>

  <form>
    <h3>Preguntas:</h3>
    [for (p : PreguntaEncuesta | e.preguntasencuesta)]
      <div class="question">
        <p><strong>[p.Texto/]</strong></p>
        [if (p.Tipo = TipoPregunta::OpcionMultiple)]
          [for (r : RespuestaEncuesta | p.respuestas_encuesta)]
            <input type="radio" name="pregunta_[p.Texto/]" value="[r.Texto/]" required> [r.Texto/]<br/>
          [/for]
        [/if]
        [if (p.Tipo = TipoPregunta::V_F)]
          <input type="radio" name="pregunta_[p.Texto/]" value="true" required> Verdadero<br/>
          <input type="radio" name="pregunta_[p.Texto/]" value="false" required> Falso<br/>
        [/if]
        [if (p.Tipo = TipoPregunta::Corta)]
          <input type="text" name="pregunta_[p.Texto/]" placeholder="Tu respuesta..." required><br/>
        [/if]
      </div>
    [/for]
    
    <div class="actions">
      <button type="submit">Enviar Encuesta</button>
      <button type="button" onclick="window.location.href='[e.usuario.Nombre.toLowerCase()/]/index.html'">Cancelar</button>
    </div>
  </form>
</body>
</html>
[/file]
[/template][/comment]