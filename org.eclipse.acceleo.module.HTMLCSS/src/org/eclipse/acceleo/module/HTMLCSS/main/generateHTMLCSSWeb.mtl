                </li>
                <li>
                  <a href="detalle_[e.Nombre.toLowerCase()/].html">[e.Nombre/] 02</a> (Acceso a los detalles)
                </li>
                <li>
                  <a href="detalle_[e.Nombre.toLowerCase()/].html">[e.Nombre/] 03</a> (Acceso a los detalles)
                </li>
                <li>
                  <a href="detalle_[e.Nombre.toLowerCase()/].html">[e.Nombre/] 04</a> (Acceso a los detalles)
                </li>
                <li>
                  <a href="detalle_[e.Nombre.toLowerCase()/].html">[e.Nombre/] 05</a> (Acceso a los detalles)
                </li>
                <li>
                  <a href="detalle_[e.Nombre.toLowerCase()/].html">[e.Nombre/] 06</a> (Acceso a los detalles)
                </li>
              </ol>

            </div>
<button onclick="window.history.back()" class="button">Volver</button>
          </div>
				

          <div class="sidebar social">
