[template public generateCuestionario(c : Cuestionario)]
  [for (acceso : Rol | c.usuario)]
    [file ('/HTML/'.concat(acceso.Nombre.toLowerCase()).concat('/cuestionario_').concat(c.Nombre.toLowerCase()).concat('.html'), false, 'UTF-8')]

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Cuestionario [c.Nombre/]</title>
  <link rel="stylesheet" href="../styles.css">
</head>
<body>
  <!-- Header Principal -->
  <div class="header">
    <h1>Cuestionario interactivo: [c.Nombre/]</h1>
  </div>

  <!-- Subheader -->
  <div class="subheader">
    <h2>Inicia el cuestionario y responde las preguntas</h2>
  </div>

  <div class="container">
    <div class="main-content">
      <div class="content">
        <p><strong>Descripción:</strong> [c.Descripcion/]</p>
        <form action="resultado_cuestionario_[c.Nombre.toLowerCase()/].html" method="post">
          [let i : Integer = 1 /]
          
          [for (preg : Pregunta | c.preguntasC)]
            <div class="pregunta">
              <p><strong>Pregunta [i/]:</strong> [preg.Texto/]</p>

              [if (preg.Tipo = TipoPregunta::OpcionMultiple)]
                [for (resp : Respuesta | preg.respuestas)]
                  <label>
                    <input type="radio" name="preg_[i/]" value="[resp.Texto/]"> [resp.Texto/]
                  </label><br>
                [/for]
              [/if]

              [if (preg.Tipo = TipoPregunta::V_F)]
                <label><input type="radio" name="preg_[i/]" value="Verdadero"> Verdadero</label><br>
                <label><input type="radio" name="preg_[i/]" value="Falso"> Falso</label><br>
              [/if]

              [if (preg.Tipo = TipoPregunta::Corta)]
                <input type="text" name="preg_[i/]" placeholder="Escribe tu respuesta..."><br>
              [/if]
            </div>
            
            [set i = i + 1 /]
          [/for]

          <div class="actions" style="margin-top: 30px;">
			  <button type="button" onclick="enviarRespuestas()">Enviar respuestas</button>
			</div>
			
			<script>
			  function enviarRespuestas() {
			    // Aquí se redirige a la página de resultados, que puede ser dinámica usando el nombre del cuestionario
			    window.location.href = "resultado_cuestionario_" + "[c.Nombre.toLowerCase()/]" + ".html";
			  }
			</script>

        </form>
      </div>
    </div>

    <div class="sidebar social">
            <h3>Redes Sociales:</h3>
            <!-- Mostrar el timeline de Twitter dentro del contenedor -->
            <div class="twitter-timeline-container">
              <a class="twitter-timeline" 
                 data-width="100%" 
                 data-height="400"
                 href="https://twitter.com/infouex?ref_src=twsrc%5Etfw">Tweets by infouex</a>
            </div>
          
            <!-- Cargar el script de Twitter de manera asíncrona -->
            <script async src="https://platform.twitter.com/widgets.js" charset="utf-8"></script>
          
            <!-- Mostrar las demás redes sociales como enlaces -->
            [for (rs : RedSocial | c.redsocial)]
              <p>- <a href="https://www.[rs.Nombre.toLowerCase()/].com" target="_blank" class="social-link">
                  [rs.Nombre/]</a></p>
            [/for]
          </div>
  </div>

  <div class="footer">
    Aplicación generada automáticamente.
  </div>

</body>
</html>

    [/file]
  [/for]
  <!-- Crear la página de resultados al final del cuestionario -->
  [for (r : Rol | c.roles)]
    [generateResultadoCuestionario(c)/]
  [/for]
[/template]

[template public generateResultadoCuestionario(c : Cuestionario)]
  [for (acceso : Rol | c.usuario)]
    [file ('/HTML/'.concat(acceso.Nombre.toLowerCase()).concat('/resultado_cuestionario_').concat(c.Nombre.toLowerCase()).concat('.html'), false, 'UTF-8')]

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Resultado del Cuestionario [c.Nombre/]</title>
  <link rel="stylesheet" href="../styles.css">
</head>
<body>
  <!-- Header Principal -->
  <div class="header">
    <h1>Resultado del Cuestionario: [c.Nombre/]</h1>
  </div>

  <!-- Subheader -->
  <div class="subheader">
    <h2>Resultado de las preguntas respondidas</h2>
  </div>

  <div class="container">
    <div class="main-content">
      <div class="content">
        <h3>Preguntas y Respuestas Correctas:</h3>

        [let i : Integer = 1 /]

        [for (preg : Pregunta | c.preguntasC)]
          <div class="pregunta">
            <p><strong>Pregunta [i/]:</strong> [preg.Texto/]</p>

            [if (preg.Tipo = TipoPregunta::OpcionMultiple)]
              <p><strong>Respuesta Correcta:</strong> [preg.respuestas->select(r | r.Rcorrecta = true)->first().Texto/]</p>
            [/if]

            [if (preg.Tipo = TipoPregunta::V_F)]
              <p><strong>Respuesta Correcta:</strong> [preg.respuestas->select(r | r.Rcorrecta = true)->first().Texto/]</p>
            [/if]

            [if (preg.Tipo = TipoPregunta::Corta)]
              <p><strong>Respuesta Correcta:</strong> [preg.RespuestaCorrecta/]</p>
            [/if]

          </div>
          
          [set i = i + 1 /]
        [/for]
      </div>
    </div>

    <div class="sidebar social">
      <h3>Redes Sociales:</h3>
      <!-- Mostrar el timeline de Twitter dentro del contenedor -->
      <div class="twitter-timeline-container">
        <a class="twitter-timeline" 
           data-width="100%" 
           data-height="400"
           href="https://twitter.com/infouex?ref_src=twsrc%5Etfw">Tweets by infouex</a>
      </div>
    
      <!-- Cargar el script de Twitter de manera asíncrona -->
      <script async src="https://platform.twitter.com/widgets.js" charset="utf-8"></script>
    
      <!-- Mostrar las demás redes sociales como enlaces -->
      [for (rs : RedSocial | c.redsocial)]
        <p>- <a href="https://www.[rs.Nombre.toLowerCase()/].com" target="_blank" class="social-link">
            [rs.Nombre/]</a></p>
      [/for]
    </div>
  </div>

  <div class="footer">
    Aplicación generada automáticamente.
  </div>

</body>
</html>

    [/file]
  [/for]
[/template]


[template public generateEncuesta(c : Encuesta)]
  [for (acceso : Rol | c.usuario)]
    [file ('/HTML/'.concat(acceso.Nombre.toLowerCase()).concat('/encuesta_').concat(c.Nombre.toLowerCase()).concat('.html'), false, 'UTF-8')]

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Encuesta - [c.Nombre/]</title>
  <link rel="stylesheet" href="../styles.css">
</head>
<body>

  <div class="header">
    <h1>Encuesta: [c.Nombre/]</h1>
  </div>

  <div class="container">
    <div class="main-content">
      <div class="content">
        <h3>Descripción de la Encuesta:</h3>
        <p>[c.Descripcion/]</p>

        <!-- Formulario para responder la encuesta -->
        <form action="#" method="post">
          
          <!-- Iteramos sobre las preguntas de la encuesta -->
          [for (preg : Pregunta | c.preguntasE)]
            <div class="pregunta">
              <p><strong>Pregunta:</strong> [preg.Texto/]</p>

              <!-- Si la pregunta es de opción múltiple -->
              [if (preg.Tipo = TipoPregunta::OpcionMultiple)]
                [for (resp : Respuesta | preg.respuestas)]
                  <label>
                    <input type="radio" name="[preg.Texto.replaceAll(' ', '_')/]" value="[resp.Texto/]"> [resp.Texto/]
                  </label><br>
                [/for]
              [/if]

              <!-- Si la pregunta es de verdadero o falso -->
              [if (preg.Tipo = TipoPregunta::V_F)]
                <label><input type="radio" name="[preg.Texto.replaceAll(' ', '_')/]" value="Verdadero"> Verdadero</label><br>
                <label><input type="radio" name="[preg.Texto.replaceAll(' ', '_')/]" value="Falso"> Falso</label><br>
              [/if]

              <!-- Si la pregunta es de respuesta corta -->
              [if (preg.Tipo = TipoPregunta::Corta)]
                <input type="text" name="[preg.Texto.replaceAll(' ', '_')/]" placeholder="Escribe tu respuesta..."><br>
              [/if]
            </div>
          [/for]

          <!-- Botón para enviar la encuesta -->
          <button type="submit">Enviar Encuesta</button>
        </form>
      </div>
    </div>

   <div class="sidebar social">
            <h3>Redes Sociales:</h3>
            <!-- Mostrar el timeline de Twitter dentro del contenedor -->
            <div class="twitter-timeline-container">
              <a class="twitter-timeline" 
                 data-width="100%" 
                 data-height="400"
                 href="https://twitter.com/infouex?ref_src=twsrc%5Etfw">Tweets by infouex</a>
            </div>
          
            <!-- Cargar el script de Twitter de manera asíncrona -->
            <script async src="https://platform.twitter.com/widgets.js" charset="utf-8"></script>
          
            <!-- Mostrar las demás redes sociales como enlaces -->
            [for (rs : RedSocial | c.redsocial)]
              <p>- <a href="https://www.[rs.Nombre.toLowerCase()/].com" target="_blank" class="social-link">
                  [rs.Nombre/]</a></p>
            [/for]
          </div>
  </div>

  <div class="footer">
    Aplicación generada automáticamente.
  </div>

</body>
</html>

    [/file]
  [/for]
[/template]

