[template public generateIndiceExtendido(e : Indice)]
  [for (acceso : Rol | e.usuario)]
    [file ('/HTML/'.concat(acceso.Nombre.toLowerCase()).concat('/indiceExtendido_Entidad_').concat(e.Nombre.toLowerCase()).concat('.html'), false, 'UTF-8')]

      <!DOCTYPE html>
      <html lang="es">
      <head>
        <meta charset="UTF-8">
        <title>Indice extendido de [e.Nombre/]</title>
        <link rel="stylesheet" href="../styles.css">
		<!-- Header Principal -->
        <div class="header">
          [for (ent : Entidad | e.entidad)]
          	<h1>[Aplicacion.allInstances()->any(rol | rol.paginapantallas->includes(e)).Nombre/]</h1>
          [/for]
        </div>

        <!-- Subheader -->
        <div class="subheader">
          <h2>Indice extendido de [e.Nombre/]</h2>
        </div>
        <style>
          /* Estilo para la lista de entidades */
.entity-list {
  list-style-type: decimal; /* Mantiene la numeración automática */
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

/* Estilo para cada elemento de la lista */
.entity-list li {
  background-color: #f9f9f9; /* Fondo suave para cada item */
  padding: 15px;
  border-radius: 8px;
  border: 1px solid #ddd; /* Borde sutil */
  box-shadow: 0 2px 6px rgba(0, 0, 0, 0.1); /* Sombra ligera */
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

/* Efecto hover para los elementos */
.entity-list li:hover {
  transform: translateY(-5px); /* Efecto de elevación */
  box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2); /* Sombra más intensa al pasar el cursor */
}

/* Estilo para los enlaces de cada item */
.entity-list li a {
  text-decoration: none;
  color: #333; /* Color de texto oscuro */
  font-size: 18px;
  font-weight: bold;
  display: block;
  transition: color 0.3s ease;
}

/* Efecto hover para los enlaces */
.entity-list li a:hover {
  color: #007BFF; /* Cambia el color del enlace al pasar el cursor */
}
          /* Pagination styling */
          .pagination {
            margin-top: 20px;
            text-align: center;
          }

          .pagination a {
            margin: 0 5px;
            padding: 10px 15px;
            background-color: #007bff;
            color: white;
            border-radius: 4px;
            text-decoration: none;
          }

          .pagination a:hover {
            background-color: #0056b3;
          }

          /* Filter section */
          form {
            margin-bottom: 20px;
          }

          label {
            font-weight: bold;
          }


        </style>
      </head>

      <body>
        <div class="container">
          <div class="main-content">
            <div class="content">

              <!-- Filtro ficticio -->
              <form method="get">
                <label for="filtroGenero">Filtrar por Genero:</label>
                <select id="filtroGenero" name="filtroGenero">
                  <option value="todos">Todos</option>
                  <option value="ficcion">Ficcion</option>
                  <option value="no-ficcion">No Ficcion</option>
                </select>
                <input type="submit" value="Aplicar filtro">
              </form>

              <h3>Listado de [e.Nombre/]</h3>

              <!-- Lista ordenada con paginacion -->
              <ol class="entity-list">
                [for (i : Integer | Sequence{1 .. 6})]
                  <li>
                    <a href="detalle_[e.Nombre.toLowerCase()/].html">[e.Nombre/] [i/]</a> (Acceso a los detalles)
                  </li>
                [/for]
              </ol>

              <!-- Paginación -->
              <div class="pagination">
                <a href="?pagina=1&filtroGenero=todos">1</a>
                <a href="?pagina=2&filtroGenero=todos">2</a>
                <a href="?pagina=3&filtroGenero=todos">3</a>
                <a href="?pagina=4&filtroGenero=todos">4</a>
              </div>

            </div>
          </div>

          <div class="sidebar social">
            <h3>Redes Sociales:</h3>
            <div class="twitter-timeline-container">
              <a class="twitter-timeline" 
                 data-width="100%" 
                 data-height="400"
                 href="https://twitter.com/infouex?ref_src=twsrc%5Etfw">Tweets by infouex</a>
            </div>
            <script async src="https://platform.twitter.com/widgets.js" charset="utf-8"></script>
            [for (rs : RedSocial | e.redsocial)]
              <p>- <a href="https://www.[rs.Nombre.toLowerCase()/].com" target="_blank" class="social-link">
                  [rs.Nombre/]</a></p>
            [/for]
          </div>
        </div>

        <div class="footer">
          Aplicacion generada automaticamente.
        </div>
      </body>
      </html>

    [/file]
  [/for]
[/template]

[template public generateIndiceDetalle(e : Indice)]
  [for (acceso : Rol | e.usuario)]
    [file ('/HTML/'.concat(acceso.Nombre.toLowerCase()).concat('/indiceDetalle_Entidad_').concat(e.Nombre.toLowerCase()).concat('.html'), false, 'UTF-8')]

    <!DOCTYPE html>
    <html lang="es">
    <head>
      <meta charset="UTF-8">
      <title>Índice y Detalle de [e.Nombre/]</title>
      <link rel="stylesheet" href="../styles.css">
<!-- Header Principal -->
<div class="header">
  [for (ent : Entidad | e.entidad)]
    <h1>[Aplicacion.allInstances()->any(rol | rol.paginapantallas->includes(e)).Nombre/]</h1>
  [/for]
</div>

<!-- Subheader -->
<div class="subheader">
  <h2>Índice extendido de [e.Nombre/]</h2>
</div>
      <style>
  /* Estilo para la lista de entidades */
  .entity-list {
    list-style-type: decimal; /* Mantiene la numeración automática */
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  /* Estilo para cada elemento de la lista */
  .entity-list li {
    background-color: #f9f9f9; /* Fondo suave para cada item */
    padding: 15px;
    border-radius: 8px;
    border: 1px solid #ddd; /* Borde sutil */
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.1); /* Sombra ligera */
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  /* Efecto hover para los elementos */
  .entity-list li:hover {
    transform: translateY(-5px); /* Efecto de elevación */
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2); /* Sombra más intensa al pasar el cursor */
  }

  /* Estilo para los enlaces de cada item */
  .entity-list li a {
    text-decoration: none;
    color: #333; /* Color de texto oscuro */
    font-size: 18px;
    font-weight: bold;
    display: block;
    transition: color 0.3s ease;
  }

  /* Efecto hover para los enlaces */
  .entity-list li a:hover {
    color: #007BFF; /* Cambia el color del enlace al pasar el cursor */
  }

  /* Sección de detalle */
  .detail {
    padding: 20px;
    background-color: #f4f4f4;
    border-radius: 8px;
    margin-left: 20px;
    width: 60%;
  }

  .detail h4 {
    color: #007bff;
  }

  .detail p {
    font-size: 14px;
    color: #555;
  }

  /* Contenedor principal */
  .container {
    display: flex;
    gap: 40px;
    margin-top: 20px;
  }

  .main-content {
    display: flex;
    width: 100%;
  }
</style>
    </head>

    <body>
      <div class="container">
        <div class="main-content">
          <!-- Sección de índice (izquierda) -->
          <div class="content">
            <h3>Listado de [e.Nombre/]</h3>
            <ol class="entity-list">
              <li><a href="#detalle1">[e.Nombre/] 01</a></li>
              <li><a href="#detalle2">[e.Nombre/] 02</a></li>
              <li><a href="#detalle3">[e.Nombre/] 03</a></li>
              <li><a href="#detalle4">[e.Nombre/] 04</a></li>
              <li><a href="#detalle5">[e.Nombre/] 05</a></li>
              <li><a href="#detalle6">[e.Nombre/] 06</a></li>
            </ol>
          </div>

          <!-- Sección de detalle (derecha) -->
<div class="detail">
  <h3>Campos:</h3>
  [for (ent : Entidad | e.entidad)] 
    <div class="field">
      [for (attr : Atributo | ent.atributos)] 
        <p>
          [attr.Nombre/] // 
          [if (attr.TipoAtributo = TipoAtributo::String)] (String) [/if]
          [if (attr.TipoAtributo = TipoAtributo::Integer)] (Integer) [/if]
          [if (attr.TipoAtributo = TipoAtributo::Boolean)] (Boolean) [/if]
        </p>
      [/for]

      <!-- Aquí se muestran las claves foráneas de la entidad -->
      [for (referencia : Entidad | ent.entidadRefereenciada)] 
        <p>- Id_[referencia.Nombre/][ ' [' 'ID del ' + referencia.Nombre+ ']' /] : Referencia a la entidad [referencia.Nombre/]</p>
      [/for]

      <div class="options" style="margin-top: 20px;">
        <h4>Listado de opciones:</h4>
        <ol style="padding-left: 20px;">
          <li style="margin-bottom: 10px;">
            <a href="borrar_[ent.Nombre.toLowerCase()/].html">Borrar [ent.Nombre/]</a>
          </li>
          [for (referencia : Entidad | ent.entidadRefereenciada)] 
            <li style="margin-bottom: 10px;">
              <a href="detalle_[referencia.Nombre.toLowerCase()/].html">Consultar detalles de [ ' [' 'ID del ' + referencia.Nombre+ ']' /] // Referencia a la entidad [referencia.Nombre/]</a>
            </li>
          [/for]
        </ol>
      </div>
    </div>
  [/for]
</div>



        </div>

        <div class="sidebar social">
          <h3>Redes Sociales:</h3>
          <div class="twitter-timeline-container">
            <a class="twitter-timeline" 
               data-width="100%" 
               data-height="400"
               href="https://twitter.com/infouex?ref_src=twsrc%5Etfw">Tweets by infouex</a>
          </div>
          <script async src="https://platform.twitter.com/widgets.js" charset="utf-8"></script>
          [for (rs : RedSocial | e.redsocial)]
            <p>- <a href="https://www.[rs.Nombre.toLowerCase()/].com" target="_blank" class="social-link">
              [rs.Nombre/]</a></p>
          [/for]
        </div>

      </div>
<button onclick="window.history.back()" class="button">Volver</button>
      <div class="footer">
        Aplicación generada automáticamente.
      </div>
    </body>
    </html>

  [/file]
  [/for]
[/template]

[template public generateContenidoNormal(p : Normal)]
  [for (acceso : Rol | p.usuario)]
    [file ('/HTML/'.concat(acceso.Nombre.toLowerCase()).concat('/pagina_normal_').concat(p.Nombre.toLowerCase()).concat('.html'), false, 'UTF-8')]

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>[p.Contenido/] - Página de contenido</title>
  <link rel="stylesheet" href="../styles.css">
  <style>
    .container {
      display: flex;
      justify-content: space-between;
      gap: 20px;
    }

    .main-content {
      flex: 1;
    }

    .sidebar {
      width: 250px;
      padding: 20px;
      background-color: #f4f4f4;
      border-radius: 8px;
    }

    /* Styles for the multimedia images */
    .multimedia-gallery {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 20px;
      padding: 20px 0;
    }

    .media-item {
      text-align: center;
    }

    .media-item img {
      width: 100%;
      height: auto;
      max-height: 180px;
      object-fit: cover;
      border-radius: 8px;
      box-shadow: 0 2px 6px rgba(0,0,0,0.1);
    }

    .media-type {
      margin-top: 8px;
      font-weight: bold;
      color: #333;
    }
  </style>
</head>
<body>
  <div class="header">
    <h1>[p.Contenido/]</h1>
  </div>

  <div class="container">
    <div class="main-content">
      <div class="content">
        <h3>Contenido Multimedia:</h3>

        <!-- Multimedia Gallery -->
		<div class="multimedia-gallery">
		  <!-- Hardcoded Image Filenames -->
		  <div class="media-item">
		    <img src="../../../images/python.png" alt="Imagen multimedia Python">
		    <p class="media-type">Normal.Tipo</p> <!-- Texto que corresponde a 'Tipo' -->
		  </div>
		
		  <div class="media-item">
		    <img src="../../../images/c++.jpg" alt="Imagen multimedia C++">
		    <p class="media-type">Normal.Tipo</p> <!-- Texto que corresponde a 'Tipo' -->
		  </div>
		
		  <div class="media-item">
		    <img src="../../../images/java.png" alt="Imagen multimedia Java">
		    <p class="media-type">Normal.Tipo</p> <!-- Texto que corresponde a 'Tipo' -->
		  </div>
		</div>



        <!-- Actions (back button) -->
        <div class="actions">
          <a href="[acceso.Nombre.toLowerCase()/]/index.html" class="button">Volver</a>
        </div>
      </div>
    </div>

    <div class="sidebar">
      <h3>Redes Sociales:</h3>
      <div class="twitter-timeline-container">
        <a class="twitter-timeline" 
           data-width="100%" 
           data-height="400"
           href="https://twitter.com/infouex?ref_src=twsrc%5Etfw">Tweets by infouex</a>
      </div>
      <script async src="https://platform.twitter.com/widgets.js" charset="utf-8"></script>

      [for (rs : RedSocial | p.redsocial)]
        <p>- <a href="https://www.[rs.Nombre.toLowerCase()/].com" target="_blank" class="social-link">
            [rs.Nombre/]</a></p>
      [/for]
    </div>
  </div>

  <div class="footer">
    Aplicación generada automáticamente.
  </div>
</body>
</html>

    [/file]
  [/for]
[/template]

