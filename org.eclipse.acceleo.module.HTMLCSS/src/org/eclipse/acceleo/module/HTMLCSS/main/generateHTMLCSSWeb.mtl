  [for (acceso : Rol | c.usuario)]
    [file ('/HTML/'.concat(acceso.Nombre.toLowerCase()).concat('/resultado_encuesta_').concat(c.Nombre.toLowerCase()).concat('.html'), false, 'UTF-8')]

