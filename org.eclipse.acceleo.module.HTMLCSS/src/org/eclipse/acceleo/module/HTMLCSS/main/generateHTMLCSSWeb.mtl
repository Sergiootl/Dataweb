[template public generateContenidoNormal(p : Normal)]
  [for (acceso : Rol | p.usuario)]
    [file ('/HTML/'.concat(acceso.Nombre.toLowerCase()).concat('/pagina_').concat(p.Nombre.toLowerCase()).concat('.html'), false, 'UTF-8')]

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>[p.Nombre/] - Página de contenido</title>
  <link rel="stylesheet" href="../styles.css">
</head>
<body>
  <div class="header">
    <h1>[p.Nombre/]</h1>
  </div>

  <div class="container">
    <div class="main-content">
      <div class="content">
        <h3>Contenido:</h3>
        <p>[p.texto/]</p>

        [for (img : Imagen | p.imagenes)]
          <div class="image">
            <img src="[img.url/]" alt="[img.descripcion/]">
          </div>
        [/for]

        [for (video : Video | p.videos)]
          <div class="video">
            <video controls>
              <source src="[video.url/]" type="video/mp4">
              Tu navegador no soporta el formato de video.
            </video>
          </div>
        [/for]

        [for (tabla : Tabla | p.tablas)]
          <div class="table">
            <h4>[tabla.Nombre/]</h4>
            <table>
              [for (fila : Fila | tabla.filas)]
                <tr>
                  [for (celda : Celda | fila.celdas)]
                    <td>[celda.Contenido/]</td>
                  [/for]
                </tr>
              [/for]
            </table>
          </div>
        [/for]

        <div class="actions">
          <a href="[acceso.Nombre.toLowerCase()/]/index.html" class="button">Volver</a>
        </div>
      </div>

    <div class="sidebar social">
            <h3>Redes Sociales:</h3>
            <!-- Mostrar el timeline de Twitter dentro del contenedor -->
            <div class="twitter-timeline-container">
              <a class="twitter-timeline" 
                 data-width="100%" 
                 data-height="400"
                 href="https://twitter.com/infouex?ref_src=twsrc%5Etfw">Tweets by infouex</a>
