      usuario="//@roles.0 //@roles.1 //@roles.2 //@roles.3"
      redsocial="//@redessociales.0 //@redessociales.1"
      entidad="//@basedatos.0/@tablas.0"
      Descripcion="¿Cuanto te ha gustado la app?">
    <preguntasE
        Tipo="Corta"
        Texto="¿Cuanto te ha gustado la app?">
      <respuestas
          Texto="Mucho"/>
      <respuestas
          Texto="Muchisimo"/>
    </preguntasE>
  </paginapantallas>
  <paginapantallas
      xsi:type="dataweb:Cuestionario"
