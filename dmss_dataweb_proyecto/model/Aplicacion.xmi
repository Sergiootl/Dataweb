  <basedatos
      Nombre="Uex">
    <tablas
        Nombre="Titulo"
        entidadRefereenciada="//@basedatos.0/@tablas.1 //@basedatos.0/@tablas.2 //@basedatos.0/@tablas.3"
        usuarios="//@roles.0 //@roles.3">
      <atributos
