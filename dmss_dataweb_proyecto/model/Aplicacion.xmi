      usuario="//@roles.0 //@roles.1 //@roles.2 //@roles.3"
      redsocial="//@redessociales.0 //@redessociales.1"
      entidad="//@basedatos.0/@tablas.0"
      Descripcion="¿Cuantos minutos tiene una hora?">
    <preguntasC
        Texto="¿Cuantos minutos tiene una hora?"
        Rcorrecta="//@paginapantallas.1/@preguntasC.0/@respuestas.0">
      <respuestas
          Texto="60"/>
      <respuestas
          Texto="70"/>
    </preguntasC>
    <preguntasC
        Tipo="V_F"
        Texto="El caballo blanco de santiago es blanco"
        Rcorrecta="//@paginapantallas.1/@preguntasC.1/@respuestas.0">
      <respuestas
          Texto="Verdadero"/>
      <respuestas
          Texto="Falso"/>
    </preguntasC>
